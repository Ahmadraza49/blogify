<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title><%= blog.title %></title>

    <style>
       body {
   background: url('/images/blog1.jpeg') no-repeat center center/cover;
   background-size: cover;
   min-height: 100vh;
   margin: 0;
   font-family: Arial, sans-serif;
}

/* 🔥 Overlay thoda smooth aur premium */
.overlay {
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(4px);
    min-height: 100vh;
    color: white;
    padding: 40px;
}

/* 🔥 Glass effect container */
.blog-container {
    max-width: 800px;
    margin: auto;
    background: rgba(17,17,17,0.85);
    padding: 25px;
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    transition: 0.3s;
}

.blog-container:hover {
    transform: translateY(-5px);
}

/* 🔥 Profile image better */
.blog-container img {
    width: 200px;
    height: 190px;
    border-radius: 50%;
    margin-bottom: 20px;
    object-fit: cover;
    border: 3px solid #19192b;
}

/* 🔥 Heading styling */
h1 {
    font-size: 2rem;
    margin-bottom: 10px;
    letter-spacing: 1px;
}

/* 🔥 Tags styling */
.tags span {
    margin-right: 5px;
    background: #7c82c7;
    padding: 5px 10px;
    border-radius: 6px;
    font-size: 12px;
}

/* 🔥 Paragraph readability */
p {
    line-height: 1.7;
    color: #ddd;
}

/* 🚀 Animated Back Button */
.btn-back {
    margin-top: 20px;
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    transition: all 0.3s ease;
    padding: 10px 18px;
}

/* Hover effect */
.btn-back:hover {
    background: linear-gradient(45deg, #4f46e5, #6366f1);
    color: #fff;
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.3);
    padding-left: 22px;
}

/* Arrow animation */
.btn-back::before {
   
    position: absolute;
    left: 10px;
    transition: 0.3s;
}

.btn-back:hover::before {
    left: 5px;
}
    </style>
</head>
<body>

<%- include('./partials/nav') %>

<div class="overlay">
    <div class="blog-container">
        <h1><%= blog.title %></h1>
        <img src="<%= blog.coverImageURL %>" alt="<%= blog.title %>">
        <p><%= blog.body %></p>

        <% if (blog.tags && blog.tags.length) { %>
            <div class="tags">        
                <% blog.tags.forEach(tag => { %>
                    <span class="badge bg-primary"><%= tag %></span>
                <% }) %>
            </div>
        <% } %>

        <a href="/" class="btn btn-light btn-back"> Back to Blogs</a>
    </div>
</div>

<%- include('./partials/scripts') %>
</body>
</html> 