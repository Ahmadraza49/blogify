<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title><%= blog.title %></title>

    <style>
        body {
           background: url('/images/blog1.jpeg') no-repeat center center/cover;
           background-size: cover;
           min-height: 100vh;
           margin: 0;
           font-family: Arial, sans-serif;
        }

        .overlay {
            background: rgba(0,0,0,0.6);
            min-height: 100vh;
            color: white;
            padding: 40px;
        }

        .blog-container {
            max-width: 800px;
            margin: auto;
            background: #111;
            padding: 20px;
            border-radius: 12px;
        }

      .blog-container img {
    width: 200px;      /* container ke width ke hisaab se */
    height: 190px;     /* height image ratio ke hisaab se adjust ho jaye */
    border-radius: 50%;
    margin-bottom: 20px;
    object-fit: cover; /* image crop avoid */
}

        h1 {
            font-size: 2rem;
            margin-bottom: 10px;
        }

        .tags span {
            margin-right: 5px;
        }

        p {
            line-height: 1.6;
        }

        .btn-back {
            margin-top: 20px;
        }
    </style>
</head>
<body>

<%- include('./partials/nav') %>

<div class="overlay">
    <div class="blog-container">
        <h1><%= blog.title %></h1>
        <img src="<%= blog.coverImageURL %>" alt="<%= blog.title %>">
        <p><%= blog.body %></p>

        <% if (blog.tags && blog.tags.length) { %>
            <div class="tags">        
                <% blog.tags.forEach(tag => { %>
                    <span class="badge bg-primary"><%= tag %></span>
                <% }) %>
            </div>
        <% } %>

        <a href="/" class="btn btn-light btn-back">← Back to Blogs</a>
    </div>
</div>

<%- include('./partials/scripts') %>
</body>
</html> 